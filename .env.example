# Variables de entorno necesarias para el proyecto
# Copia este archivo como .env y completa los valores

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenAI Configuration (opcional - para funciones de IA educativa)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini Configuration (opcional - alternativa a OpenAI)
GEMINI_API_KEY=your_gemini_api_key_here
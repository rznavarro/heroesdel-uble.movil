# Configuración NPM para el proyecto
# Suprimir warnings de dependencias deprecated específicas
audit-level=moderate
fund=false

# Configuración para Vercel
legacy-peer-deps=false
strict-peer-deps=false

# Suprimir warning específico de node-domexception
# Este paquete está deprecated pero es usado por dependencias internas
# y no afecta la funcionalidad de la aplicación